      <aliases enabled='yes' />
      <column caption='Total_Miles' datatype='real' name='[Calculation_484699909920116736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[EmptyDrivingDistance]+[LoadedDrivingDistance]' />
      </column>
      <column caption='Profit' datatype='real' name='[Calculation_484699909920239617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Revenue_Split]-[TR_PayAmount]' />
      </column>
      <column caption='Average Revenue Per Mile' datatype='real' name='[Calculation_484699909920915458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Revenue_Split]) / sum([Calculation_484699909920116736])' />
      </column>
      <column caption='Year_2023' datatype='string' name='[Calculation_484699909929537539]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if YEAR([SH_DelDate]) = 2023 then [DriverId]&#13;&#10;ELSE &quot; &quot;&#13;&#10;END' />
      </column>
      <column caption='Blanks' datatype='string' name='[Calculation_677510270718836736]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([TripId]) OR&#13;&#10;   ISNULL([SH_ID]) OR&#13;&#10;   ISNULL([TripKey]) OR&#13;&#10;   ISNULL([TrailerId]) OR&#13;&#10;   ISNULL([TruckId]) OR&#13;&#10;   ISNULL([ShipmentKey]) OR&#13;&#10;   ISNULL([DriverId]) OR&#13;&#10;   ISNULL([EmptyDrivingDistance]) OR&#13;&#10;   ISNULL([LoadedDrivingDistance]) OR&#13;&#10;   ISNULL([SH_PU_Address]) OR&#13;&#10;   ISNULL([SH_PU_Municipality]) OR&#13;&#10;   ISNULL([SH_PU_AdministrativeArea]) OR&#13;&#10;   ISNULL([SH_TO_Municipality]) OR&#13;&#10;   ISNULL([SH_TO_AdministrativeArea]) OR&#13;&#10;   ISNULL([SH_CreatedBy]) OR&#13;&#10;   ISNULL([SH_DelDate]) OR&#13;&#10;   ISNULL([Disp_Key]) OR&#13;&#10;   ISNULL([TR_PayAmount]) OR&#13;&#10;   ISNULL([TR_Status]) OR&#13;&#10;   ISNULL([SH_CustomerId]) OR&#13;&#10;   ISNULL([IsInvoiced]) OR&#13;&#10;   ISNULL([Revenue_Split])&#13;&#10;THEN &quot;Has Blank Fields&quot;&#13;&#10;ELSE &quot;Complete&quot;&#13;&#10;END' />
      </column>
      <column caption='Is_Blank' datatype='integer' name='[Calculation_677510270721007617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_677510270718836736] = &quot;Has Blank Fields&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='blank_%' datatype='real' name='[Calculation_677510270721998853]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Calculation_677510270721007617])/ COUNT([TripId])' />
      </column>
