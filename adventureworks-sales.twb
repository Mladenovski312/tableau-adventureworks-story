            <column caption='Blanks' datatype='string' name='[Calculation_677510270718836736]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([TripId]) OR&#13;&#10;   ISNULL([SH_ID]) OR&#13;&#10;   ISNULL([TripKey]) OR&#13;&#10;   ISNULL([TrailerId]) OR&#13;&#10;   ISNULL([TruckId]) OR&#13;&#10;   ISNULL([ShipmentKey]) OR&#13;&#10;   ISNULL([DriverId]) OR&#13;&#10;   ISNULL([EmptyDrivingDistance]) OR&#13;&#10;   ISNULL([LoadedDrivingDistance]) OR&#13;&#10;   ISNULL([SH_PU_Address]) OR&#13;&#10;   ISNULL([SH_PU_Municipality]) OR&#13;&#10;   ISNULL([SH_PU_AdministrativeArea]) OR&#13;&#10;   ISNULL([SH_TO_Municipality]) OR&#13;&#10;   ISNULL([SH_TO_AdministrativeArea]) OR&#13;&#10;   ISNULL([SH_CreatedBy]) OR&#13;&#10;   ISNULL([SH_DelDate]) OR&#13;&#10;   ISNULL([Disp_Key]) OR&#13;&#10;   ISNULL([TR_PayAmount]) OR&#13;&#10;   ISNULL([TR_Status]) OR&#13;&#10;   ISNULL([SH_CustomerId]) OR&#13;&#10;   ISNULL([IsInvoiced]) OR&#13;&#10;   ISNULL([Revenue_Split])&#13;&#10;THEN &quot;Has Blank Fields&quot;&#13;&#10;ELSE &quot;Complete&quot;&#13;&#10;END' />
